# === Azure OpenAI (Judge Model for Evaluations) ===
# Authentication method: "api_key" (default, for development) or "managed_identity" (for production)
AZURE_AUTH_METHOD=api_key

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# API Key - Required when AZURE_AUTH_METHOD=api_key, not needed for managed_identity
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-05-01-preview

# === Container App Agent (Target Agent to Evaluate) ===
# Your container app REST API endpoint
AGENT_ENDPOINT=https://your-container-app.azurecontainerapps.io/api/chat
# Optional: Bearer token if your container app requires authentication
AGENT_API_KEY=
